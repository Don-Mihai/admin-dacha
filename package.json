{
  "name": "utkina-dacha-admin",
  "version": "1.0.0",
  "description": "Общая админка для редактирования данных проектов Уткина дача",
  "type": "module",
  "main": "server.pkg.cjs",
  "bin": "server.pkg.cjs",
  "scripts": {
    "start": "node server.pkg.cjs",
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "node server.pkg.cjs",
    "build": "vite build",
    "build:exe": "npm run build && pkg . --targets node18-win-x64 --output utkina-admin.exe",
    "pkg": "pkg . --targets node18-win-x64 --output utkina-admin.exe"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.6",
    "@mui/material": "^6.1.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "pkg": "^5.8.1",
    "vite": "^5.4.10"
  },
  "pkg": {
    "scripts": "server.pkg.cjs",
    "assets": [
      "dist/**/*"
    ]
  }
}